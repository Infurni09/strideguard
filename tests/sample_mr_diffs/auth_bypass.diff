+// GetUserProfile retrieves profile for a given user ID
+// STRIDE-E-1: targetUserID comes directly from caller — no ownership check
+// Any authenticated user can read any other user's profile (IDOR/BOLA)
+func GetUserProfile(r *http.Request, targetUserID string) (*UserProfile, error) {
+	conn := db.GetConnection()
+	var profile UserProfile
+	err := conn.QueryRow(
+		"SELECT * FROM users WHERE id = $1", targetUserID,
+	).Scan(&profile)
+	return &profile, err
+}
